# ─────────────────────────────────────────────────────────────
# Environment template — copy to .env.local and fill in.
# NOTE: deliberately NO Ayrshare / Brandfetch / Apify keys.
# We build those capabilities in-house (see docs/04-integrations.md).
# ─────────────────────────────────────────────────────────────

# --- Core infra ---
DATABASE_URL="postgresql://user:password@localhost:5432/social_platform"
REDIS_URL="redis://localhost:6379"
# Scheduling engine heartbeat (P4-01): how often (ms) the worker scans for due
# content items and auto-publishes them. Defaults to 60000 (1 min).
# SCHEDULER_TICK_MS="60000"

# Object storage (S3-compatible, e.g. Cloudflare R2)
STORAGE_ENDPOINT=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# App
APP_BASE_URL="http://localhost:3000"
LOG_LEVEL="info"               # debug | info | warn | error
# Signs the session JWT (>=16 chars). Generate: openssl rand -hex 32
JWT_SECRET=""
# Encrypts stored OAuth tokens at rest (>=32 chars). Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=""
# Where generated media is stored locally (swap to S3/R2 later)
ASSET_STORAGE_DIR="./.assets"

# --- AI compute (metered — the irreducible cost) ---
ANTHROPIC_API_KEY=""           # LLM: planning, copy, brand-voice analysis
IMAGE_GEN_PROVIDER="fake"      # fake | imagen | ideogram | selfhosted
IMAGE_GEN_API_KEY=""           # image gen (Imagen 4 Fast / Ideogram v3 / Nano Banana 2)

# --- Video pipeline (P3-01: script → B-roll → TTS → assembly) ---
TTS_PROVIDER="fake"            # fake | openai | elevenlabs | selfhosted (narration voiceover)
TTS_API_KEY=""                 # set to switch off the fake TTS
VIDEO_ASSEMBLER="fake"         # fake | ffmpeg (ffmpeg shells out to the local binary)
FFMPEG_PATH="ffmpeg"           # path/name of the ffmpeg binary when VIDEO_ASSEMBLER=ffmpeg

# --- Self-hosted open gen models on our own GPU (P3-07) ---
# Set the *_URL and switch IMAGE_GEN_PROVIDER / TTS_PROVIDER to `selfhosted`.
# SELF_HOSTED_IMAGE_URL=""       # e.g. http://gpu-box:8000/v1/images/generations
SELF_HOSTED_IMAGE_MODEL="sdxl"
# SELF_HOSTED_TTS_URL=""         # e.g. http://gpu-box:8001/v1/audio/speech
SELF_HOSTED_TTS_MODEL="xtts-v2"
# SELF_HOSTED_GEN_TOKEN=""       # optional bearer for the internal endpoints

# --- Free data sources we build on ---
YOUTUBE_DATA_API_KEY=""        # competitor discovery + trending (free quota)
# GOOGLE_TRENDS uses public endpoints — no key

# --- Publishing: ONE platform for the MVP (pick fastest app review) ---
# LinkedIn
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/connections/linkedin/callback"
# Meta (Instagram / Facebook) — alternative MVP platform
# META_APP_ID=""
# META_APP_SECRET=""

# X (Twitter) — OAuth 2.0 confidential client + API v2 (P3-03). Paid API; only
# set these when a client actually needs X publishing.
# X_CLIENT_ID=""
# X_CLIENT_SECRET=""
# X_REDIRECT_URI="http://localhost:3000/api/connections/x/callback"

# Pinterest — OAuth 2.0 + API v5 (P3-04).
# PINTEREST_APP_ID=""
# PINTEREST_APP_SECRET=""
# PINTEREST_REDIRECT_URI="http://localhost:3000/api/connections/pinterest/callback"

# --- Billing: Stripe subscriptions for agencies (P3-05) ---
# STRIPE_SECRET_KEY=""              # sk_live_... / sk_test_...
# STRIPE_WEBHOOK_SECRET=""         # whsec_... (signs /api/billing/webhook)
# STRIPE_PRICE_STARTER=""          # price_... for the Starter plan
# STRIPE_PRICE_PRO=""              # price_... for the Pro plan

# --- Notifications & alerts (P4-06) ---
# Slack/email targets are configured per-agency in the app (Notification
# settings). These set the shared email send endpoint + the milestone threshold.
# NOTIFY_EMAIL_ENDPOINT=""         # JSON endpoint accepting { to, subject, body }
# NOTIFY_EMAIL_TOKEN=""            # optional bearer for the email endpoint
# NOTIFY_MILESTONE_IMPRESSIONS="10000"  # impressions that trigger a milestone alert

# --- Agency reporting (P4-07) ---
# Reuses NOTIFY_EMAIL_ENDPOINT for delivery. Digest recipient per agency =
# white-label supportEmail. Set REPORT_DIGEST_MS=0 to disable the schedule.
# REPORT_DIGEST_MS="604800000"     # scheduled digest cadence (default 7 days)
# REPORT_PERIOD_DAYS="30"          # window each report covers

# --- Deferred (NOT in MVP) ---
# PROXY_URL=""                 # residential proxies for scraping — scale only
