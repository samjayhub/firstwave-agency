# ─────────────────────────────────────────────────────────────
# Environment template — copy to .env.local and fill in.
# NOTE: deliberately NO Ayrshare / Brandfetch / Apify keys.
# We build those capabilities in-house (see docs/04-integrations.md).
# ─────────────────────────────────────────────────────────────

# --- Core infra ---
DATABASE_URL="postgresql://user:password@localhost:5432/social_platform"
REDIS_URL="redis://localhost:6379"

# Object storage (S3-compatible, e.g. Cloudflare R2)
STORAGE_ENDPOINT=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# App
NEXTAUTH_SECRET=""
APP_URL="http://localhost:3000"
# Key used to encrypt stored OAuth tokens at rest
TOKEN_ENCRYPTION_KEY=""

# --- AI compute (metered — the irreducible cost) ---
ANTHROPIC_API_KEY=""           # LLM: planning, copy, brand-voice analysis
IMAGE_GEN_API_KEY=""           # image gen (Imagen 4 Fast / Ideogram v3 / Nano Banana 2)
# VIDEO_GEN_API_KEY=""         # Phase 3 (Veo / Sora)
# ELEVENLABS_API_KEY=""        # Phase 3 voiceover

# --- Free data sources we build on ---
YOUTUBE_DATA_API_KEY=""        # competitor discovery + trending (free quota)
# GOOGLE_TRENDS uses public endpoints — no key

# --- Publishing: ONE platform for the MVP (pick fastest app review) ---
# LinkedIn
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
# Meta (Instagram / Facebook) — alternative MVP platform
# META_APP_ID=""
# META_APP_SECRET=""

# --- Deferred (NOT in MVP) ---
# X_API_KEY=""                 # paid API — deferred
# PROXY_URL=""                 # residential proxies for scraping — scale only
