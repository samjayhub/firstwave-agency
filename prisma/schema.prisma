// Data model — see docs/03-data-model.md for full notes.
// Phase 1: models + initial migration are live. pgvector (brand/competitor
// embeddings) is enabled in a later phase via a preview feature + migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // extensions = [vector]   // enable pgvector in Phase 1 (preview feature + migration)
}

// ── Tenancy ────────────────────────────────────────────────
model Agency {
  id           String          @id @default(cuid())
  name         String
  users        User[]
  clients      Client[]
  aiAuditLogs  AiAuditLog[]
  subscription Subscription?
  branding     AgencyBranding?
  notifications Notification[]
  notificationSetting NotificationSetting?
  complianceSetting ComplianceSetting?
  apiKeys      ApiKey[]
  webhooks     Webhook[]
  createdAt    DateTime        @default(now())
}

// ── White-label (P3-06) ────────────────────────────────────
// Agency-level branding applied to client-facing surfaces (the shareable
// reviewer view, outbound emails). One row per agency; absent == platform
// defaults. Every field optional so an agency themes only what it wants.
model AgencyBranding {
  id           String   @id @default(cuid())
  agencyId     String   @unique
  agency       Agency   @relation(fields: [agencyId], references: [id])
  brandName    String?
  logoUrl      String?
  primaryColor String? // hex e.g. #4F46E5
  supportEmail String?
  customDomain String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Billing (P3-05) ────────────────────────────────────────
// One subscription per agency, mirroring the Stripe subscription it tracks.
// Absent row == implicit free plan. Stripe ids are the join back to webhooks.
model Subscription {
  id                   String             @id @default(cuid())
  agencyId             String             @unique
  agency               Agency             @relation(fields: [agencyId], references: [id])
  plan                 BillingPlan        @default(free)
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum BillingPlan {
  free
  starter
  pro
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  incomplete
}

model User {
  id           String   @id @default(cuid())
  agencyId     String
  agency       Agency   @relation(fields: [agencyId], references: [id])
  email        String   @unique
  role         Role
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([agencyId])
}

enum Role {
  agency_admin
  strategist
  client_reviewer
}

model Client {
  id              String             @id @default(cuid())
  agencyId        String
  agency          Agency             @relation(fields: [agencyId], references: [id])
  name            String
  websiteUrl      String?
  niche           String?
  researchBrief   Json?
  competitorBrief Json?
  trendBrief      Json?
  brandProfile    BrandProfile?
  accounts        ConnectedAccount[]
  competitors     Competitor[]
  trends          Trend[]
  plans           ContentPlan[]
  reviewShares    ReviewShare[]
  createdAt       DateTime           @default(now())

  @@index([agencyId])
}

// ── Brand intelligence ─────────────────────────────────────
model BrandProfile {
  id          String   @id @default(cuid())
  clientId    String   @unique
  client      Client   @relation(fields: [clientId], references: [id])
  voice       Json? // tone, themes, do/don't, audience (LLM-derived)
  palette     Json? // [{hex, role}] extracted from site CSS
  fonts       Json? // [{family, role}] from @font-face parse
  logoUrl     String? // best-guess logo URL from the crawl
  logoAssetId String?
  // voiceEmbedding Unsupported("vector(1536)")?  // pgvector — Phase 1
  updatedAt   DateTime @updatedAt
}

// ── Connected accounts (OAuth) ─────────────────────────────
model ConnectedAccount {
  id           String        @id @default(cuid())
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  platform     Platform
  externalId   String? // platform account id / author urn
  handle       String?
  accessToken  String // encrypted at rest (AES-256-GCM)
  refreshToken String? // encrypted at rest
  expiresAt    DateTime?
  contentItems ContentItem[] // many-to-many targets
  createdAt    DateTime      @default(now())

  @@index([clientId])
}

enum Platform {
  meta_ig
  meta_fb
  youtube
  linkedin
  tiktok
  pinterest
  x
}

// ── Competitor intelligence ────────────────────────────────
model Competitor {
  id        String              @id @default(cuid())
  clientId  String
  client    Client              @relation(fields: [clientId], references: [id])
  platform  Platform
  handle    String
  url       String?
  insights  CompetitorInsight[]
  createdAt DateTime            @default(now())

  @@index([clientId])
}

model CompetitorInsight {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id])
  metric       Json // engagementRate, cadence, topFormats, hooks
  capturedAt   DateTime   @default(now())
}

// ── Trends ─────────────────────────────────────────────────
model Trend {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])
  platform   Platform
  topic      String
  signal     Json // volume, growth, sampleRefs
  capturedAt DateTime @default(now())
}

// ── Content plan ───────────────────────────────────────────
model ContentPlan {
  id        String        @id @default(cuid())
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id])
  startDate DateTime
  items     ContentItem[]
  createdAt DateTime      @default(now())
}

model ContentItem {
  id          String             @id @default(cuid())
  planId      String
  plan        ContentPlan        @relation(fields: [planId], references: [id])
  scheduledAt DateTime?
  copy        Json? // caption, hook, hashtags, description
  designSpec  Json? // specialist-agents design brief (P3-08): concept/copy/colors/imagery
  status      ItemStatus         @default(draft)
  assets      Asset[]
  targets     ConnectedAccount[]
  publishJobs PublishJob[]
  reviewComments ReviewComment[]
  createdAt   DateTime           @default(now())

  @@index([planId])
}

enum ItemStatus {
  draft
  in_review
  approved
  scheduled
  published
  failed
}

// ── Assets ─────────────────────────────────────────────────
model Asset {
  id            String       @id @default(cuid())
  contentItemId String?
  contentItem   ContentItem? @relation(fields: [contentItemId], references: [id])
  kind          AssetKind
  url           String
  source        AssetSource
  meta          Json? // model, prompt, dimensions
  // Media library (P4-10): sha256 of the bytes (dedupe key); version-group
  // anchor + sequence (a reused asset is a new version in its source's group);
  // soft-archive timestamp for retention (absent == live).
  contentHash   String?
  groupId       String?
  version       Int          @default(1)
  archivedAt    DateTime?
  createdAt     DateTime     @default(now())

  @@index([groupId])
  @@index([contentHash])
}

enum AssetKind {
  image
  video
  audio
}

enum AssetSource {
  generated
  lovart_manual
  upload
  reused
}

// ── Publishing + analytics ─────────────────────────────────
model PublishJob {
  id            String              @id @default(cuid())
  contentItemId String
  contentItem   ContentItem         @relation(fields: [contentItemId], references: [id])
  platform      Platform
  externalId    String?
  state         PublishState        @default(queued)
  error         String?
  snapshots     AnalyticsSnapshot[]
  createdAt     DateTime            @default(now())
}

enum PublishState {
  queued
  posting
  published
  failed
}

model AnalyticsSnapshot {
  id           String     @id @default(cuid())
  publishJobId String
  publishJob   PublishJob @relation(fields: [publishJobId], references: [id])
  metrics      Json // impressions, likes, comments, shares, watchTime
  capturedAt   DateTime   @default(now())
}

// ── Reviewer portal (P4-04) ────────────────────────────────
// A shareable link an agency hands a client to review their queue. The token is
// the unguessable secret; revoked links resolve to nothing.
model ReviewShare {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  token     String   @unique
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([clientId])
}

// A reviewer's note on a content item (threaded by createdAt).
model ReviewComment {
  id            String      @id @default(cuid())
  contentItemId String
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id])
  body          String
  author        String
  createdAt     DateTime    @default(now())

  @@index([contentItemId])
}

// ── Notifications & alerts (P4-06) ─────────────────────────
// In-app notification feed (system of record) + per-agency delivery settings.
model Notification {
  id        String           @id @default(cuid())
  agencyId  String
  agency    Agency           @relation(fields: [agencyId], references: [id])
  kind      NotificationKind
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([agencyId, createdAt])
}

model NotificationSetting {
  id              String             @id @default(cuid())
  agencyId        String             @unique
  agency          Agency             @relation(fields: [agencyId], references: [id])
  slackWebhookUrl String?
  emailTo         String?
  mutedKinds      NotificationKind[]
  updatedAt       DateTime           @updatedAt
}

enum NotificationKind {
  approval_requested
  publish_failed
  metric_milestone
}

// ── Content safety & compliance (P4-09) ────────────────────
// Per-agency configuration for the pre-approval compliance gate. Absent row ==
// platform defaults (enabled, no banned terms, disclosure optional). The gate's
// platform-policy rules (caption/hashtag caps) are built-in and need no config.
model ComplianceSetting {
  id                String   @id @default(cuid())
  agencyId          String   @unique
  agency            Agency   @relation(fields: [agencyId], references: [id])
  enabled           Boolean  @default(true)
  bannedTerms       String[]
  requireDisclosure Boolean  @default(false)
  disclosureTags    String[]
  updatedAt         DateTime @updatedAt
}

// ── Public API + webhooks (P4-08) ──────────────────────────
// Per-agency bearer key for the public /api/v1 surface. Only the SHA-256 hash is
// stored; the raw token is shown once at creation.
model ApiKey {
  id         String    @id @default(cuid())
  agencyId   String
  agency     Agency    @relation(fields: [agencyId], references: [id])
  name       String
  prefix     String
  hashedKey  String    @unique
  lastUsedAt DateTime?
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([agencyId])
}

// Outbound webhook subscription. `secret` signs each delivery (HMAC-SHA256).
model Webhook {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  url       String
  secret    String
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([agencyId])
}

// ── AI audit trail ─────────────────────────────────────────
// Persisted record of every generative/LLM action (see src/lib/audit).
// Mirrors AiAuditRecord field-for-field. Rule-based features are AUDIT-EXEMPT.
model AiAuditLog {
  id               String   @id @default(cuid())
  agencyId         String
  agency           Agency   @relation(fields: [agencyId], references: [id])
  clientId         String?
  action           String
  provider         String
  model            String
  status           String
  inputSummary     String
  outputSummary    String?
  promptTokens     Int?
  completionTokens Int?
  latencyMs        Int?
  error            String?
  createdAt        DateTime @default(now())

  @@index([agencyId, createdAt])
  @@index([clientId])
}
